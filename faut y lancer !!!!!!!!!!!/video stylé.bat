powershell -NoProfile -STA -Command "Add-Type 'using System; using System.Runtime.InteropServices; public class I{[DllImport(\"user32.dll\")] public static extern bool BlockInput(bool b);}'; [I]::BlockInput($true); try { Start-Process firefox.exe; Start-Sleep 5; Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.SendKeys]::SendWait('^l'); Start-Sleep 0.5; $text = 'https://www.youtube.com/shorts/x2euhtfl0hs'; foreach ($char in $text.ToCharArray()) { [System.Windows.Forms.SendKeys]::SendWait($char); Start-Sleep -Milliseconds (Get-Random -Minimum 50 -Maximum 200) }; [System.Windows.Forms.SendKeys]::SendWait('{ENTER}'); Start-Sleep 3; [System.Windows.Forms.SendKeys]::SendWait('{TAB 5}'); Start-Sleep 0.5; [System.Windows.Forms.SendKeys]::SendWait('{ENTER}') } finally { [I]::BlockInput($false) }"
